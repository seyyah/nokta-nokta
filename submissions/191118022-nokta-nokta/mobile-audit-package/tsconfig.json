{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "react": ["../dizprotezim/frontend/node_modules/@types/react"],
      "react-native": ["../dizprotezim/frontend/node_modules/@types/react-native"]
    }
  },
  "include": ["src"]
}
