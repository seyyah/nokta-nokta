{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@xtatistix/mobile-audit": ["node_modules/@xtatistix/mobile-audit/src/index.ts"],
      "expo-file-system/src/legacy": ["node_modules/expo-file-system/src/legacy/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
