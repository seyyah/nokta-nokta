{
  "expo": {
    "name": "Nokta Voice Avatar Bridge",
    "slug": "nokta-expert-support",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0e1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nokta.voiceavatarbridge",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Mikrofon, ses dalga görselleştirmesi ve avatar dudak senkronu için kullanılır.",
        "NSCameraUsageDescription": "Uzman görüntülü görüşmesinde kamera kullanılır."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "com.nokta.voiceavatarbridge",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Ses görselleştirme ve avatar lipsync için mikrofon erişimi gerekli."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eadaf5a6-e9e8-4638-be95-f494efa4e352"
      }
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/avatar-scene.html",
      "assets/avatar.glb"
    ]
  }
}
